class Solution {
    public boolean canPlaceFlowers(int[] flo, int n) {
        int m=flo.length;
        if(n==0) return true;
        for(int i=0;i<m;i++){
            if((flo[i]==0) && (i==0 || flo[i-1]==0) && (i==m-1 || flo[i+1]==0)){
                flo[i]=1;
                n--;
                if(n==0) return true;
            }
        }
         return false;
    }
}
